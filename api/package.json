{
  "name": "cotizador-api",
  "version": "0.1.0",
  "description": "Backend API for professional quotation system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "psql -h localhost -U postgres -d quotations -f scripts/migrate.sql",
    "db:seed": "psql -h localhost -U postgres -d quotations -f scripts/seed.sql",
    "lint": "eslint src"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "pg": "^8.12.0",
    "puppeteer": "^22.6.5",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.13",
    "@types/pg": "^8.11.8",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
